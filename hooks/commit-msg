#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 David Kristiansen

# commit-msg — validate conventional commit format
#
# Enforces the Conventional Commits specification (https://www.conventionalcommits.org/).
# Install via: make hooks
#
# Allowed types:
#   feat fix docs style refactor perf test build ci chore revert
#
# Format:
#   <type>[(<scope>)][!]: <description>
#   [blank line]
#   [body]
#   [blank line]
#   [footer(s)]
#
# Examples:
#   feat(fold): add XDG barrier support
#   fix: handle symlink-only subdirectories in completeness check
#   refactor(stow)!: rename __create_link to __link
#   docs: update AGENTS.md with auto-unfold architecture

set -euo pipefail

COMMIT_MSG_FILE="$1"

# Read the first non-comment, non-empty line (the subject line)
subject=""
while IFS= read -r line; do
    # Skip git comments
    [[ "$line" =~ ^# ]] && continue
    # Skip empty lines before subject
    [[ -z "$line" ]] && continue
    subject="$line"
    break
done <"$COMMIT_MSG_FILE"

if [[ -z "$subject" ]]; then
    echo >&2 "ERROR: Empty commit message."
    exit 1
fi

# Allow merge commits
if [[ "$subject" =~ ^Merge\  ]]; then
    exit 0
fi

# Allow revert commits generated by git
if [[ "$subject" =~ ^Revert\  ]]; then
    exit 0
fi

# Conventional commit regex:
#   type      = feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert
#   scope     = optional, in parentheses, alphanumeric + dash + dot
#   breaking  = optional trailing !
#   separator = ": " (colon + space)
#   subject   = non-empty
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"
PATTERN="^(${TYPES})(\([a-zA-Z0-9._-]+\))?\!?: .+"

if ! [[ "$subject" =~ $PATTERN ]]; then
    echo >&2 ""
    echo >&2 "ERROR: Commit message does not follow Conventional Commits format."
    echo >&2 ""
    echo >&2 "  Subject: $subject"
    echo >&2 ""
    echo >&2 "  Expected format: <type>[(<scope>)][!]: <description>"
    echo >&2 ""
    echo >&2 "  Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    echo >&2 ""
    echo >&2 "  Examples:"
    echo >&2 "    feat(fold): add XDG barrier support"
    echo >&2 "    fix: handle empty directories in completeness check"
    echo >&2 "    refactor(stow)!: rename internal link function"
    echo >&2 ""
    exit 1
fi

# Validate subject line length (soft limit: 72 chars)
if (( ${#subject} > 72 )); then
    echo >&2 "WARNING: Subject line is ${#subject} characters (recommended max: 72)."
    # Warning only, don't block the commit
fi

# Validate description starts with lowercase (convention, not hard requirement)
desc="${subject#*: }"
if [[ "$desc" =~ ^[A-Z] ]]; then
    echo >&2 "WARNING: Description should start with lowercase: '$desc'"
    # Warning only, don't block the commit
fi
